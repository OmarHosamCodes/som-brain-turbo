{
	"name": "som-brain-turbo",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^5",
			"next": "^16.1.1",
			"@trpc/server": "^11.7.2",
			"@trpc/client": "^11.7.2",
			"better-auth": "^1.4.18"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"db:push": "turbo -F @som-brain-turbo/db db:push",
		"db:studio": "turbo -F @som-brain-turbo/db db:studio",
		"db:generate": "turbo -F @som-brain-turbo/db db:generate",
		"db:migrate": "turbo -F @som-brain-turbo/db db:migrate",
		"db:start": "turbo -F @som-brain-turbo/db db:start",
		"db:watch": "turbo -F @som-brain-turbo/db db:watch",
		"db:stop": "turbo -F @som-brain-turbo/db db:stop",
		"db:down": "turbo -F @som-brain-turbo/db db:down",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@som-brain-turbo/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@som-brain-turbo/config": "workspace:*",
		"@types/node": "^22.13.14",
		"turbo": "^2.6.3",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.8"
}
